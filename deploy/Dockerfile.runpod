ARG BASE_IMAGE=foundry-base-llama-cpp:latest
FROM ${BASE_IMAGE}

ENV FOUNDRY_MODEL_NAME=Qwen3.5-35B-A3B
ENV FOUNDRY_GGUF_REPO=unsloth/Qwen3.5-35B-A3B-GGUF
ENV FOUNDRY_GGUF_FILE=Qwen3.5-35B-A3B-Q4_K_M.gguf
ENV FOUNDRY_PORT=8080
ENV FOUNDRY_HOST=0.0.0.0
ENV FOUNDRY_CTX_LENGTH=65536
ENV FOUNDRY_THREADS=16
ENV FOUNDRY_PARALLEL=2
ENV RUNPOD_DEBUG=false

COPY models/qwen3.5-35b-a3b/profiles/ /opt/foundry/profiles/
COPY models/qwen3.5-35b-a3b/entrypoint.sh /opt/foundry/entrypoint.sh
COPY deploy/runpod-start.sh /opt/foundry/start.sh
RUN chmod +x /opt/foundry/*.sh

RUN mkdir -p /models

WORKDIR /app
EXPOSE 8080

ENTRYPOINT ["/opt/foundry/start.sh"]
