# ==============================================================================
# Foundry RunPod Serverless Image
# ==============================================================================

ARG BASE_IMAGE=ghcr.io/infernet-org/foundry/qwen3.5-35b-a3b:latest
FROM ${BASE_IMAGE}

# Install RunPod SDK
RUN apt-get update && apt-get install -y python3-pip && \
    pip3 install --no-cache-dir runpod requests && \
    rm -rf /var/lib/apt/lists/*

ENV FOUNDRY_PORT=8080
ENV FOUNDRY_HOST=127.0.0.1

COPY deploy/runpod-start.sh /opt/foundry/start.sh
COPY deploy/handler.py /opt/foundry/handler.py
RUN chmod +x /opt/foundry/start.sh

WORKDIR /app

ENTRYPOINT ["/opt/foundry/start.sh"]
