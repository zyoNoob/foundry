# ==============================================================================
# Foundry RunPod Serverless Image
# ==============================================================================
# Thin layer on top of the model image adding RunPod-specific entrypoint
# for graceful shutdown and health checking in a serverless context.
# ==============================================================================

ARG BASE_IMAGE=ghcr.io/infernet-org/foundry/qwen3.5-35b-a3b:latest
FROM ${BASE_IMAGE}

ENV FOUNDRY_PORT=8080
ENV FOUNDRY_HOST=0.0.0.0
ENV FOUNDRY_CTX_LENGTH=65536
ENV FOUNDRY_THREADS=16
ENV FOUNDRY_PARALLEL=2
ENV RUNPOD_DEBUG=false

COPY runpod-start.sh /opt/foundry/start.sh
RUN chmod +x /opt/foundry/start.sh

WORKDIR /app
EXPOSE 8080

ENTRYPOINT ["/opt/foundry/start.sh"]
